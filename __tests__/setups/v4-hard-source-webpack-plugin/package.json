{
  "name": "v4-hard-source-webpack-plugin",
  "version": "0.0.1",
  "description": "Test webpack v4, and HardSourceWebpackPlugin with SMP",
  "scripts": {
    "full-test": "bun run prepare && bun run test && bun run cleanup",
    "postinstall": "bun ../../../scripts/fix-v4-hard-source-webpack-plugin.js",
    "prepare": "cp -r ../../common/* .",
    "test": "bun test ./smp.fixture.js",
    "cleanup": "rm -rf dist && rm -rf node_modules/.cache",
    "audit-fix": "bun audit"
  },
  "license": "MIT",
  "packageManager": "bun@1.3.8",
  "engines": {
    "node": ">=6.0.0"
  },
  "devDependencies": {
    "babel-core": "^6.26.3",
    "babel-loader": "^7.1.4",
    "css-loader": "^0.28.11",
    "hard-source-webpack-plugin": "^0.6.4",
    "style-loader": "^0.20.3",
    "webpack": "^4.47.0"
  }
}
